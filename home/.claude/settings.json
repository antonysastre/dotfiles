{
  "env": {
    "EDITOR": "zed --wait"
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sastre/.claude/hooks/no-code-comments.sh",
            "statusMessage": "Checking commit for explanatory comments…"
          }
        ]
      }
    ]
  },
  "respondToBashCommands": false,
  "statusLine": {
    "type": "command",
    "command": "/Users/sastre/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "vim",
  "autoCompactEnabled": true,
  "fileCheckpointingEnabled": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
