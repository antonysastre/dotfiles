# GENERAL
1. docker build --file <dockerfile> --tag <image_name:tag> <target> // Build an image from Dockerfile
2. docker container create --name <container_name> <command> //  Create a container from the image
3. docker container start <container_name> // Start a container

1. docker container stop <container_name> // Stop a container
2. docker container rm <container_name> // Remove a container
3. docker images rm <image_name:tag> // Remove image

# IMAGES
docker build -t <image_name> //-> Build an Image from a Dockerfile
docker images //-> List local images
docker rmi <image_name> //-> Delete an Image
docker image prune //-> Remove all unused images

# DOCKER HUB
docker login -u <username> //-> Login into Docker
docker push <username>/<image_name> //-> Publish an image to Docker Hub
docker search <image_name> //-> Search Hub for an image
docker pull <image_name> //-> Pull an image from a Docker Hub

# CONTAINERS
docker ps <--all> //-> To list currently running containers
docker run <-d> --name <container_name> <image_name> //-> Create and run a container from an image.
docker run -it --name <container_name> <image_name> //-> Create and run a container from an image.
docker run -p <host_port>:<container_port> <image_name> //-> Run a container and connect ports
docker start|stop <container_name|container-id> //-> Start or stop an existing containe
docker rm <container_name> //-> Remove a stopped container
docker exec <container_name> <command> //-> Run a command in the container
docker exec -it <container_name> sh //-> Open a shell inside a running container
docker logs -f <container_name> //-> Fetch and follow the logs of a container
docker inspect <container_name> (or <container_id>) //-> To inspect a running container
docker container stats //-> View resource usage stats
