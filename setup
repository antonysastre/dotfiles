#!/bin/bash
set -e

DOTFILES="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"

if [ "$OS" = "Linux" ]; then
    echo "Linux detected."

    if command -v apt &>/dev/null; then
        # ── Debian / Ubuntu / Zorin ──
        echo "  Detected apt-based system."

        sudo apt update -qq
        for _pkg in stow btop gh fonts-firacode libyaml-dev; do
            if ! dpkg -s "$_pkg" &>/dev/null 2>&1; then
                echo "  Installing $_pkg..."
                sudo apt install -y -qq "$_pkg"
            fi
        done

        if ! command -v starship &>/dev/null; then
            echo "  Installing Starship..."
            curl -fsSL https://starship.rs/install.sh | sh -s -- -y
        fi

        if ! command -v mise &>/dev/null; then
            echo "  Installing Mise..."
            curl -fsSL https://mise.run | sh
        fi

        if ! command -v ghostty &>/dev/null; then
            echo "  Installing Ghostty..."
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh)"
        fi

        if command -v gsettings &>/dev/null; then
            current_xkb=$(gsettings get org.gnome.desktop.input-sources xkb-options 2>/dev/null)
            if [[ "$current_xkb" != *"ctrl:nocaps"* ]]; then
                echo "  Remapping Caps Lock to Control..."
                gsettings set org.gnome.desktop.input-sources xkb-options "['ctrl:nocaps']"
            fi
        fi

    elif command -v pacman &>/dev/null; then
        # ── Arch Linux ──
        echo "  Detected pacman-based system."

        sudo pacman -Syu --noconfirm --needed stow btop github-cli starship ghostty ttf-fira-code libyaml

        if ! command -v mise &>/dev/null; then
            echo "  Installing Mise..."
            curl -fsSL https://mise.run | sh
        fi
    fi

    # ── Common Linux steps ──
    mkdir -p ~/.claude

    cd "$DOTFILES"
    stow -t ~ home --ignore=Library

    if ! command -v zed &>/dev/null; then
        echo "  Installing Zed..."
        curl -fsSL https://zed.dev/install.sh | sh
    fi

    if ! grep -q 'source ~/.aliases' ~/.bashrc 2>/dev/null; then
        {
            echo ''
            echo '# Dotfiles'
            echo 'export EDITOR="zed"'
            echo 'export PATH="$HOME/.local/bin:$PATH"'
            echo 'source ~/.aliases'
            echo 'eval "$(mise activate bash)"'
            echo 'eval "$(starship init bash)"'
            echo '[ -f ~/.localrc ] && source ~/.localrc'
        } >> ~/.bashrc
        echo "Dotfiles config appended to ~/.bashrc"
    fi

    echo "Done!"
    exit 0
fi

# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Install/update Homebrew packages
brew bundle --file="$DOTFILES/Brewfile"

# Ensure ~/.claude exists so stow descends into it (per-file symlinks)
# rather than folding the whole dir into the repo (which would pull in
# sessions, credentials, cache, etc.)
mkdir -p ~/.claude

# Symlink dotfiles via stow — fails loudly on conflict so you can resolve manually
cd "$DOTFILES"
stow -t ~ home

# Create Projects directory
mkdir -p ~/Projects

# Set Zed as default editor for code files via Launch Services
duti -s dev.zed.Zed public.plain-text all
duti -s dev.zed.Zed public.source-code all
duti -s dev.zed.Zed public.shell-script all
duti -s dev.zed.Zed public.json all
duti -s dev.zed.Zed public.yaml all
duti -s dev.zed.Zed public.xml all

# Remap Caps Lock to Control (persists until reboot, plist handles login)
hidutil property --set '{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x7000000E0}]}' > /dev/null

echo "Done! Restart your shell or run: source ~/.zshrc"
echo "Put machine-specific config in ~/.localrc (not tracked)."
